{
  "name": "assistim-admin-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --require ./scripts/vite-windows-spawn-patch.cjs ./node_modules/vite/bin/vite.js --configLoader native --host 127.0.0.1 --port 5174",
    "build": "tsc --noEmit && node --require ./scripts/vite-windows-spawn-patch.cjs ./node_modules/vite/bin/vite.js build --configLoader native",
    "preview": "vite preview --host 127.0.0.1 --port 4174",
    "test": "node --require ./scripts/vite-windows-spawn-patch.cjs ./node_modules/vitest/vitest.mjs run --configLoader runner --pool=threads"
  },
  "dependencies": {
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.0.1",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "7.3.2",
    "vitest": "3.2.4"
  }
}
