APP_NAME=AssistIM API
APP_VERSION=1.0
DEBUG=true
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/assistim
SECRET_KEY=assistim-dev-secret-change-me
ACCESS_TOKEN_EXPIRE=60
REFRESH_TOKEN_EXPIRE_DAYS=7
UPLOAD_DIR=data/uploads
API_V1_PREFIX=/api/v1
API_COMPAT_PREFIX=/api
CORS_ORIGINS=*
RATE_LIMIT_LOGIN=5
RATE_LIMIT_REGISTER=3
RATE_LIMIT_EMAIL_VERIFICATION=5
RATE_LIMIT_FRIEND_REQUEST=10
EMAIL_PROVIDER=console
EMAIL_FROM=no-reply@assistim.local
EMAIL_VERIFICATION_TTL_SECONDS=600
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
EMAIL_VERIFICATION_MAX_ATTEMPTS=5
EMAIL_VERIFICATION_EXPOSE_CODE=false
EMAIL_VERIFICATION_FILE_PATH=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
