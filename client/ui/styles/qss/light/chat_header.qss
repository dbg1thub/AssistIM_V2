QWidget#chatHeader {
    background: transparent;
    border: none;
}

QLabel#chatHeaderTitle {
    color: {{TEXT_PRIMARY}};
    font: 16px "Segoe UI Semibold", "Microsoft YaHei", "PingFang SC";
}

QLabel#chatHeaderStatus {
    color: {{TEXT_SECONDARY}};
    font: 12px "Segoe UI", "Microsoft YaHei", "PingFang SC";
}
