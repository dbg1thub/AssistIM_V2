QWidget#SettingsInterface,
QWidget#settingsScrollWidget,
QWidget#settingsViewport {
    background: transparent;
    border: none;
}

QAbstractScrollArea {
    background: transparent;
    border: none;
}

SettingCardGroup {
    background: transparent;
}

SettingCardGroup > QLabel {
    background: transparent;
    color: {{TEXT_PRIMARY}};
    border: none;
    padding-left: 2px;
    font: 20px "Segoe UI", "Microsoft YaHei", "PingFang SC";
}
