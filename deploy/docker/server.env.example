POSTGRES_DB=assistim
POSTGRES_USER=assistim
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD

APP_NAME=AssistIM API
APP_VERSION=0.1.2
DEBUG=false
SECRET_KEY=CHANGE_ME_LONG_RANDOM_SECRET
ACCESS_TOKEN_EXPIRE=60
REFRESH_TOKEN_EXPIRE_DAYS=7
MEDIA_STORAGE_BACKEND=local
MEDIA_PUBLIC_BASE_URL=/uploads
MAX_UPLOAD_BYTES=104857600
API_V1_PREFIX=/api/v1
API_PORT=8000
CORS_ORIGINS=*
RATE_LIMIT_LOGIN=5
RATE_LIMIT_REGISTER=3
RATE_LIMIT_EMAIL_VERIFICATION=5
RATE_LIMIT_FRIEND_REQUEST=10
RATE_LIMIT_STORE_BACKEND=database
EMAIL_PROVIDER=smtp
EMAIL_FROM=no-reply@example.com
EMAIL_VERIFICATION_TTL_SECONDS=600
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
EMAIL_VERIFICATION_MAX_ATTEMPTS=5
EMAIL_VERIFICATION_EXPOSE_CODE=false
EMAIL_VERIFICATION_FILE_PATH=
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=CHANGE_ME_SMTP_USER
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_USE_TLS=true
WEBRTC_ICE_SERVER_URLS=
WEBRTC_STUN_URLS=stun:stun.l.google.com:19302
# Remote voice/video calls require a relay-capable TURN server. STUN-only
# deployments can signal calls, but media may stay in Connecting behind NAT.
WEBRTC_TURN_URLS=
WEBRTC_TURN_USERNAME=
WEBRTC_TURN_CREDENTIAL=
WEBRTC_TURN_SHARED_SECRET=
WEBRTC_TURN_CREDENTIAL_TTL_SECONDS=3600
